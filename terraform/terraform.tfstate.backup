            "json": "{\n  \"Version\": \"2012-10-17\",\n  \"Statement\": [\n    {\n      \"Effect\": \"Allow\",\n      \"Action\": \"sts:AssumeRoleWithWebIdentity\",\n      \"Principal\": {\n        \"Federated\": \"arn:aws:iam::598529167500:oidc-provider/oidc.eks.ap-southeast-1.amazonaws.com/id/4A2EFCA77306A2B393C3041009D942DC\"\n      },\n      \"Condition\": {\n        \"StringEquals\": {\n          \"oidc.eks.ap-southeast-1.amazonaws.com/id/4A2EFCA77306A2B393C3041009D942DC:aud\": \"sts.amazonaws.com\",\n          \"oidc.eks.ap-southeast-1.amazonaws.com/id/4A2EFCA77306A2B393C3041009D942DC:sub\": \"system:serviceaccount:kube-system:ebs-csi-controller-sa\"\n        }\n      }\n    }\n  ]\n}",
            "minified_json": "{\"Version\":\"2012-10-17\",\"Statement\":[{\"Effect\":\"Allow\",\"Action\":\"sts:AssumeRoleWithWebIdentity\",\"Principal\":{\"Federated\":\"arn:aws:iam::598529167500:oidc-provider/oidc.eks.ap-southeast-1.amazonaws.com/id/4A2EFCA77306A2B393C3041009D942DC\"},\"Condition\":{\"StringEquals\":{\"oidc.eks.ap-southeast-1.amazonaws.com/id/4A2EFCA77306A2B393C3041009D942DC:aud\":\"sts.amazonaws.com\",\"oidc.eks.ap-southeast-1.amazonaws.com/id/4A2EFCA77306A2B393C3041009D942DC:sub\":\"system:serviceaccount:kube-system:ebs-csi-controller-sa\"}}}]}",
